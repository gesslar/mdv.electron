{
  "name": "mdv",
  "private": true,
  "description": "An offline Markdown viewer for everybody! For free! Huzzah!",
  "version": "1.0.0",
  "type": "module",
  "license": "0BSD",
  "author": "gesslar <bmw@gesslar.dev>",
  "homepage": "https://github.com/gesslar/mdv",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesslar/mdv.git"
  },
  "main": "src/app/index.js",
  "scripts": {
    "postinstall": "node -e \"if(process.platform!=='win32')require('child_process').execSync('patch-package',{stdio:'inherit'})\"",
    "start": "electron-forge start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "update": "npx npm-check-updates -u && npm install",
    "pr": "gt submit --publish --restack --ai",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:squirrel": "electron-forge make --targets=@electron-forge/maker-squirrel",
    "make:zip": "electron-forge make --targets=@electron-forge/maker-zip",
    "make:deb": "electron-forge make --targets=@electron-forge/maker-deb",
    "make:rpm": "electron-forge make --targets=@electron-forge/maker-rpm",
    "make:appimage": "electron-forge make --targets=@reforged/maker-appimage",
    "make:flatpak": "electron-forge make --targets=@electron-forge/maker-flatpak -- --ccache"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-flatpak": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@gesslar/uglier": "^2.4.1",
    "@reforged/maker-appimage": "^5.2.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "electron": "^41.3.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14",
    "patch-package": "^8.0.1"
  },
  "dependencies": {
    "@gesslar/toolkit": "^5.2.0",
    "@highlightjs/cdn-assets": "^11.11.1",
    "@vscode/codicons": "^0.0.45",
    "dompurify": "^3.4.1",
    "electron-squirrel-startup": "^1.0.1",
    "marked": "^18.0.2",
    "marked-highlight": "^2.2.4"
  }
}
