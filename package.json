{
  "name": "mdv",
  "private": true,
  "description": "An offline Markdown viewer for everybody! For free! Huzzah!",
  "version": "1.0.2",
  "type": "module",
  "license": "0BSD",
  "author": "gesslar <bmw@gesslar.dev>",
  "homepage": "https://github.com/gesslar/mdv.electron",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gesslar/mdv.electron.git"
  },
  "main": "src/app/index.js",
  "scripts": {
    "start": "electron .",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "update": "npx npm-check-updates -u && npm install",
    "pr": "gt submit -p --ai",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major",
    "package": "electron-builder --dir",
    "dist": "electron-builder --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "dist:deb": "electron-builder --linux deb --x64 --arm64 --publish never",
    "dist:rpm": "electron-builder --linux rpm --x64 --arm64 --publish never",
    "dist:appimage": "electron-builder --linux AppImage --x64 --arm64 --publish never",
    "dist:flatpak": "node scripts/build-flatpak.mjs",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "clean": "node scripts/clean-out.mjs"
  },
  "devDependencies": {
    "@gesslar/uglier": "^2.4.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@gesslar/toolkit": "^5.2.0",
    "@highlightjs/cdn-assets": "^11.11.1",
    "@vscode/codicons": "^0.0.45",
    "dompurify": "^3.4.1",
    "marked": "^18.0.2",
    "marked-highlight": "^2.2.4"
  }
}
