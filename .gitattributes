# Force LF on anything run on a Unix host. Without this, Windows checkouts
# with core.autocrlf=true can hand CRLF-laden scripts to bash and break them.

*.sh            text eol=lf
*.mjs           text eol=lf
*.js            text eol=lf
*.cjs           text eol=lf

# JSON/YAML/MD — LF keeps diffs clean across OSes.
*.json          text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.md            text eol=lf

# Windows-only: keep CRLF.
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

# Binaries — never touch.
*.png           binary
*.ico           binary
*.icns          binary
*.rpm           binary
*.deb           binary
*.AppImage      binary
*.exe           binary
*.dll           binary
